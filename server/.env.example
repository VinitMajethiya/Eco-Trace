# Server Port Configuration
PORT=5000

# Node Environment: production, development, or test
NODE_ENV=development

# JSON Web Token signing secret
JWT_SECRET=your-jwt-signing-secret-here

# Allowed CORS client origin
CLIENT_ORIGIN=http://localhost:5173

# Google Gemini API Key for AI Coaching Recommendations (optional, falls back gracefully to template summaries if missing)
GEMINI_API_KEY=your-gemini-api-key-here

# Authentication rate limiter maximum requests per 15 minutes window (optional, defaults to 15)
AUTH_RATE_LIMIT_MAX=15

# Google Cloud OAuth Client ID for social login integration (optional, Google button hidden if missing)
GOOGLE_CLIENT_ID=your-google-oauth-client-id-here

# Google Cloud OAuth Client Secret (optional)
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret-here

# Google Cloud OAuth Authorized Redirect URL (optional, e.g. http://localhost:5000/api/auth/google/callback)
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
